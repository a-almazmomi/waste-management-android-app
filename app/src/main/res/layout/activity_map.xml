<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    android:padding="16dp">

    <!-- Profile Picture and Points -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/profile_picture"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/profile_picture"
            android:contentDescription="Profile picture" />

        <TextView
            android:id="@+id/points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:text="340 points"
            android:textSize="16sp"
            android:textColor="#333"
            android:contentDescription="User points" />
    </LinearLayout>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/search_bar"
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:layout_toEndOf="@id/points"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/search_bar_background"
        android:hint="Search"
        android:paddingStart="16dp"
        android:gravity="center_vertical"
        android:inputType="text"
        android:autofillHints="username"
        android:contentDescription="Search field" />

    <!-- Google Map -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/search_bar"
        android:layout_marginTop="16dp"
        android:layout_above="@id/bottom_navigation" />

    <!-- Bottom Navigation Icons -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp">

        <ImageButton
            android:id="@+id/qrButton"
            android:layout_width="175dp"
            android:layout_height="40dp"
            android:background="#00000000"
            android:src="@drawable/icon" />

        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="#00000000"
            android:src="@drawable/iconn" />

        <ImageButton
            android:id="@+id/locationButton"
            android:layout_width="165dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="#00000000"
            android:src="@drawable/iconnn"
            android:tint="@color/green"/>
    </LinearLayout>

</RelativeLayout>

